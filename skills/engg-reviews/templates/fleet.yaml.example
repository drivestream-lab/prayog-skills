# Fleet layout for engg-reviews (Phase 1 — local Graphify)
# Paths are relative to this pe-workspace directory. Edit for your fleet.

fleet_root: ..
pe_workspace: .
meta_repo: REPLACE-meta-repo-name
meta_path: ../REPLACE-meta-repo-name
integration_branch: develop
codegraph_provider: local-graphify

layout:
  graphs_dir: graphs
  reports_dir: out/reports

meta:
  prd_root: ../REPLACE-meta-repo-name/prd
  reports_dir: ../REPLACE-meta-repo-name/prd/reports

repos:
  example-service:
    path: ../example-service
    as_built: ../example-service/docs/specification/as-built/implementation-status.md
    graph: graphs/example-service/graphify-out/graph.json

